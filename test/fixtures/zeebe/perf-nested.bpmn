          <zeebe:output source="=mapped2 + 2" target="result2" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_2" targetRef="End_1" />
    <bpmn:endEvent id="End_1">
