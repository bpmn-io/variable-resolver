          <bpmn:extensionElements>
            <zeebe:ioMapping>
              <zeebe:output source="=sub3Result" target="sub3Out" />
            </zeebe:ioMapping>
          </bpmn:extensionElements>
          <bpmn:subProcess id="Sub_4">
            <bpmn:extensionElements>
              <zeebe:ioMapping>
                <zeebe:output source="=sub4Result" target="sub4Out" />
              </zeebe:ioMapping>
            </bpmn:extensionElements>
            <bpmn:subProcess id="Sub_5">
