              </bpmn:extensionElements>
              <bpmn:serviceTask id="Task_deep_1">
                <bpmn:extensionElements>
                  <zeebe:ioMapping>
                    <zeebe:input source="=inputA" target="mappedA" />
                    <zeebe:output source="=resultA" target="outA" />
                  </zeebe:ioMapping>
                </bpmn:extensionElements>
              </bpmn:serviceTask>
              <bpmn:serviceTask id="Task_deep_2">
                <bpmn:extensionElements>
                  <zeebe:ioMapping>
