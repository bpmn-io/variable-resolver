              </bpmn:serviceTask>
              <bpmn:serviceTask id="Task_deep_3">
                <bpmn:extensionElements>
                  <zeebe:ioMapping>
                    <zeebe:input source="=inputC" target="mappedC" />
                    <zeebe:output source="=resultC" target="outC" />
                  </zeebe:ioMapping>
                </bpmn:extensionElements>
              </bpmn:serviceTask>
            </bpmn:subProcess>
          </bpmn:subProcess>
        </bpmn:subProcess>
      </bpmn:subProcess>
