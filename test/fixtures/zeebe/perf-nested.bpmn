    <bpmn:sequenceFlow id="Flow_0" sourceRef="Start_1" targetRef="Sub_1" />
    <bpmn:subProcess id="Sub_1">
      <bpmn:incoming>Flow_0</bpmn:incoming>
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:output source="=sub1Result" target="sub1Out" />
